# ── Database (Supabase Postgres, proyek: PintuTrack / lmxxuvkstnfapqtuktvk) ──
# Aplikasi terhubung sebagai role khusus `pintu_app` (bukan `postgres`).
# Gunakan transaction pooler (port 6543) — cocok untuk serverless/Next.js.
# Catatan: hostname pooler proyek ini adalah aws-0 (cek Project Settings → Database bila berubah).
DATABASE_URL=postgresql://pintu_app.lmxxuvkstnfapqtuktvk:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Better Auth ──────────────────────────────────────────────────
# Buat dengan: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# ── Bot Telegram (opsional, untuk fitur catat via chat) ──────────
# 1. Buat bot lewat @BotFather → dapatkan token
# 2. Daftarkan webhook:
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<APP_URL>/api/telegram&secret_token=<SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ── Sinkronisasi Google Sheets (opsional) ────────────────────────
# 1. Google Cloud Console → buat project → aktifkan "Google Sheets API"
# 2. IAM & Admin → Service Accounts → buat service account → Keys → JSON
# 3. Salin client_email dan private_key dari file JSON ke sini
#    (private_key boleh satu baris dengan \n literal)
# 4. Tiap user membagikan spreadsheet-nya (akses Editor) ke email tsb
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
